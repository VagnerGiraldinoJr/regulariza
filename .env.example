APP_NAME="CPF Clean Brasil"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=America/Sao_Paulo

# Localização e Regionalização
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

# Dados do Servidor/Unidade
SERVER_CITY="Ponta Grossa"
SERVER_UF=PR
SERVER_COUNTRY=Brasil

# Drivers de Sistema
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12
PHP_CLI_SERVER_WORKERS=4

# Logs
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# Banco de Dados
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=sail
DB_PASSWORD=password

FORWARD_DB_PORT=3307
FORWARD_REDIS_PORT=6380

# Sessão e Cache
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
MEMCACHED_HOST=127.0.0.1

# Configurações de E-mail (Hostinger)
MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=smtp.example.com
MAIL_PORT=465
MAIL_USERNAME=contato@example.com
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="contato@cpfclean.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# Frontend (Vite)
VITE_APP_NAME="${APP_NAME}"

# Busca (Meilisearch)
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_NO_ANALYTICS=false

# ZAPI (WhatsApp) - Removida duplicidade de imagem
ZAPI_INSTANCE=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
ZAPI_WELCOME_IMAGE_URL=

# Integração API Brasil
APIBRASIL_BASE_URL=https://gateway.apibrasil.io
APIBRASIL_TOKEN=
APIBRASIL_TOKEN_HEADER=Authorization
APIBRASIL_TOKEN_PREFIX=Bearer
APIBRASIL_CPF_PATH=/api/v2/consulta/cpf/credits
APIBRASIL_CNPJ_PATH=/api/v2/consulta/cnpj/credits
APIBRASIL_CPF_METHOD=POST
APIBRASIL_CNPJ_METHOD=POST
APIBRASIL_TIMEOUT=20

# Regras de Negócio e Comissões
DEFAULT_ANALYST_EMAIL=analista@cpfclean.com.br
RESEARCH_COMMISSION_RATE=0.30
INSTALLMENT_COMMISSION_RATE=0.40
COMMISSION_HOLD_HOURS=24
CPFCLEAN_SITE_URL=https://cpfclean.com.br

# Pagamentos (Asaas)
ASAAS_BASE_URL=https://asaas.com/api/v3
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
